// Prisma 7 schema — generator must specify moduleFormat = "cjs" for NestJS (CommonJS) compatibility.
// No Rust engine in Prisma 7: driver adapter (@prisma/adapter-pg) is required.
// datasource url is now configured in prisma.config.ts (Prisma 7 breaking change).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String                @id @default(uuid())
  email               String                @unique
  name                String
  passwordHash        String                @map("password_hash")
  createdAt           DateTime              @default(now()) @map("created_at")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  participants        Participant[]
  challenges          Challenge[]           @relation("CreatedChallenges")
  notifications       Notification[]

  @@map("users")
}

model Challenge {
  id            String          @id @default(uuid())
  title         String
  emoji         String
  durationDays  Int             @map("duration_days")
  collabAmount  Decimal         @map("collab_amount") @db.Decimal(10, 2)
  platformFee   Decimal         @default(10) @map("platform_fee") @db.Decimal(10, 2)
  status        ChallengeStatus @default(WAITING)
  creatorId     String          @map("creator_id")
  creator       User            @relation("CreatedChallenges", fields: [creatorId], references: [id])
  participants  Participant[]
  invites       Invite[]
  payments      Payment[]
  evidences     Evidence[]
  createdAt     DateTime        @default(now()) @map("created_at")
  startsAt      DateTime?       @map("starts_at")

  @@map("challenges")
}

model Participant {
  id          String            @id @default(uuid())
  challengeId String            @map("challenge_id")
  challenge   Challenge         @relation(fields: [challengeId], references: [id])
  userId      String            @map("user_id")
  user        User              @relation(fields: [userId], references: [id])
  status      ParticipantStatus @default(INVITED)
  joinedAt    DateTime          @default(now()) @map("joined_at")
  paidAt      DateTime?         @map("paid_at")
  pixKey      String?           @map("pix_key")
  payments    Payment[]
  evidences   Evidence[]
  votes       Vote[]

  @@unique([challengeId, userId])
  @@map("participants")
}

model Invite {
  id          String       @id @default(uuid())
  token       String       @unique @default(uuid())
  targetEmail String       @map("target_email")
  challengeId String       @map("challenge_id")
  challenge   Challenge    @relation(fields: [challengeId], references: [id])
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime?    @map("expires_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  acceptedAt  DateTime?    @map("accepted_at")

  @@index([token])
  @@index([targetEmail])
  @@map("invites")
}

enum ChallengeStatus {
  WAITING    // aguardando turma
  ACTIVE     // no ar (Phase 2+)
  FINISHED   // finalizado (Phase 4+)
  CANCELLED  // cancelado (Phase 2+)
}

enum ParticipantStatus {
  INVITED
  PAID    // Phase 2
  ACTIVE  // Phase 2
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Payment {
  id                String        @id @default(uuid())
  externalId        String?       @unique @map("external_id")
  participantId     String        @map("participant_id")
  participant       Participant   @relation(fields: [participantId], references: [id])
  challengeId       String        @map("challenge_id")
  challenge         Challenge     @relation(fields: [challengeId], references: [id])
  amount            Decimal       @db.Decimal(10, 2)
  status            PaymentStatus @default(PENDING)
  rawWebhookPayload Json?         @map("raw_webhook_payload")
  createdAt         DateTime      @default(now()) @map("created_at")
  paidAt            DateTime?     @map("paid_at")
  refundedAt        DateTime?     @map("refunded_at")
  pixKey            String?       @map("pix_key")

  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  APPROVED
  CANCELLED
  REFUND_PENDING
  REFUNDED
  PAYOUT_PENDING
  PAID_OUT
}

model Evidence {
  id                String        @id @default(uuid())
  challengeId       String        @map("challenge_id")
  challenge         Challenge     @relation(fields: [challengeId], references: [id])
  participantId     String        @map("participant_id")
  participant       Participant   @relation(fields: [participantId], references: [id])
  objectKey         String        @map("object_key")
  evidenceDate      String        @map("evidence_date")
  status            EvidenceStatus @default(PENDING)
  windowClosesAt    DateTime      @map("window_closes_at")
  postedAt          DateTime      @default(now()) @map("posted_at")
  resolvedAt        DateTime?     @map("resolved_at")
  votes             Vote[]

  @@unique([participantId, evidenceDate])
  @@index([status, windowClosesAt])
  @@map("evidences")
}

enum EvidenceStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Vote {
  id            String      @id @default(uuid())
  evidenceId    String      @map("evidence_id")
  evidence      Evidence    @relation(fields: [evidenceId], references: [id])
  voterId       String      @map("voter_id")
  voter         Participant @relation(fields: [voterId], references: [id])
  value         VoteValue
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([evidenceId, voterId])
  @@map("votes")
}

enum VoteValue {
  SIM
  NAO
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  entityId  String           @map("entity_id")
  payload   Json             @default("{}")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@unique([userId, type, entityId])
  @@index([userId, readAt])
  @@map("notifications")
}

enum NotificationType {
  INVITE_RECEIVED
  PAYMENT_CONFIRMED
  EVIDENCE_SUBMITTED
  EVIDENCE_VALIDATED
  EVIDENCE_REMINDER
  CHALLENGE_FINALIZED
  CHALLENGE_CANCELLED
  CHALLENGE_ACTIVATED
  EVIDENCE_REJECTED
}
