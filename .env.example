# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bora?schema=public"

# App
NODE_ENV=development
PORT=3000

# CORS
FRONTEND_URL=http://localhost:5173

# Cookie (leave unset in local dev — only set in production)
# COOKIE_DOMAIN=.bora.app

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=Bora <noreply@bora.app>

# Storage (V1 local ephemeral evidence store — photos kept 24h, swept by EvidenceCleanupJob)
# STORAGE_DRIVER selects the object-storage adapter: 'local' (default) or 'r2'.
STORAGE_DRIVER=local
# Backend base URL used to build the local upload/read URLs (PUT/GET /storage/:key).
PUBLIC_BASE_URL=http://localhost:3000
# Where evidence photos are written on disk (default: <cwd>/var/evidences).
LOCAL_STORAGE_DIR=var/evidences
# HMAC secret for signing the short-lived local upload URLs. If empty, a per-boot
# random secret is used (fine for local dev; set a stable value in production).
STORAGE_SIGNING_SECRET=change-me-storage-signing-secret

# Cloudflare R2 (only needed when STORAGE_DRIVER=r2 — the future swap-back path)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=bora-evidences
# R2_PUBLIC_BASE_URL=

# --- Payments: selecao de provider (dev) ---
# 'mercadopago' (default, usado em producao) | 'fake' (dev-only)
# 'fake' ativa o FakePixAdapter: cobrancas Pix simuladas que se auto-aprovam e
# disparam o webhook real assinado. O boot FALHA se PAYMENT_PROVIDER=fake com
# NODE_ENV=production - dinheiro real nunca passa por um adapter falso.
# Necessario porque o sandbox do Mercado Pago nunca aprova cobrancas Pix de teste.
PAYMENT_PROVIDER=mercadopago

# Atraso (ms) ate o FakePixAdapter auto-aprovar a cobranca e disparar o webhook. Default: 8000.
FAKE_PIX_APPROVE_DELAY_MS=8000

# URL do webhook que o fake chama. Default: http://127.0.0.1:${PORT:-3000}/payments/webhook
# Use 127.0.0.1, nunca localhost (resolve por IPv6 e cai no lugar errado).
# FAKE_PIX_WEBHOOK_URL=http://127.0.0.1:3000/payments/webhook

# Segredo HMAC do webhook do Mercado Pago (dashboard MP > Webhooks).
# OBRIGATORIO tambem com PAYMENT_PROVIDER=fake: o fake assina o webhook que ele
# mesmo dispara com esse segredo, e o PaymentsService o exige via getOrThrow.
# MERCADOPAGO_WEBHOOK_SECRET=
