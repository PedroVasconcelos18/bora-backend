# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bora?schema=public"

# App
NODE_ENV=development
PORT=3000

# CORS
FRONTEND_URL=http://localhost:5173

# Cookie (leave unset in local dev — only set in production)
# COOKIE_DOMAIN=.bora.app

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=Bora <noreply@bora.app>
